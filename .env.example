# PolyWeatherBot — Environment Configuration
# Copy this to .env and fill in values

# -----------------------------------------------------------------------
# Database (SQLite for local, PostgreSQL for production)
# -----------------------------------------------------------------------
DATABASE_URL=sqlite:///./tradingbot.db
# DATABASE_URL=postgresql://user:pass@localhost/tradingbot

# -----------------------------------------------------------------------
# Telegram (CLI alerts + command polling)
# -----------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# -----------------------------------------------------------------------
# Weather APIs
# -----------------------------------------------------------------------
OPENWEATHER_API_KEY=

# -----------------------------------------------------------------------
# Polymarket (CLOB API — HMAC-SHA256 auth)
# -----------------------------------------------------------------------
POLY_PRIVATE_KEY=
POLY_API_KEY=
POLY_API_SECRET=
POLY_API_PASSPHRASE=
POLYMARKET_PROXY=direct

# -----------------------------------------------------------------------
# Kalshi API (RSA-PSS key auth for weather markets)
# -----------------------------------------------------------------------
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=
KALSHI_ENABLED=true

# -----------------------------------------------------------------------
# AI API Keys (optional, for contract parsing)
# -----------------------------------------------------------------------
ANTHROPIC_API_KEY=
AI_MODEL=claude-sonnet-4-20250514
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# -----------------------------------------------------------------------
# Trading — General
# -----------------------------------------------------------------------
SIMULATION_MODE=true
PAPER_TRADING=true
INITIAL_BANKROLL=10000
BANKROLL=1000

# -----------------------------------------------------------------------
# BTC 5-min trading
# -----------------------------------------------------------------------
SCAN_INTERVAL_SECONDS=60
SETTLEMENT_INTERVAL_SECONDS=120
MIN_EDGE_THRESHOLD=0.02
MAX_ENTRY_PRICE=0.55
KELLY_FRACTION=0.15
MAX_TRADE_SIZE=75
DAILY_LOSS_LIMIT=300

# -----------------------------------------------------------------------
# Weather trading
# -----------------------------------------------------------------------
WEATHER_ENABLED=true
WEATHER_SCAN_INTERVAL_SECONDS=300
WEATHER_MIN_EDGE_THRESHOLD=0.08
WEATHER_MAX_ENTRY_PRICE=0.70
WEATHER_MAX_TRADE_SIZE=100
WEATHER_CITIES=nyc,chicago,miami,los_angeles,denver

# CLI-specific weather settings
SCAN_INTERVAL_SEC=120
MIN_EDGE=0.08
MAX_BET_USD=25.0
CLI_KELLY_FRACTION=0.25

# -----------------------------------------------------------------------
# Economics data (future use)
# -----------------------------------------------------------------------
FRED_API_KEY=
BLS_API_KEY=

# -----------------------------------------------------------------------
# Frontend (optional)
# -----------------------------------------------------------------------
VITE_MAPBOX_TOKEN=
